using Gtk 4.0;
using Adw 1;

Adw.PreferencesDialog _preference_window {
  Adw.PreferencesPage {
    Adw.PreferencesGroup {
      title: _("Audio");
      Adw.ComboRow _quality_row {
        model: StringList {
          strings [
            _("Low 96k"),
            _("High 320k"),
            _("Lossless"),
            _("Hi-res Lossless"),
          ]
        };

        title: _("Quality");
      }
      Adw.ComboRow _sink_row {
        model: StringList {
          strings [
            _("Automatic"),
            "PulseAudio",
            "ALSA",
            "Jack",
            "OSS",
            "Pipewire",
          ]
        };

        title: _("Preferred Audio Sink");
        subtitle: _("Gapless playback is disabled for the native Pipewire Sink due to a bug. Use 'Automatic' for gapless playback.");
      }
      Adw.ComboRow _alsa_device_row{
        title: _("ALSA Device");
        subtitle: _("Device used for exclusive ALSA access");
      }
      Adw.SwitchRow _normalize_row {
        title: _("Normalize volume");
      }
    }

    Adw.PreferencesGroup {
      title: _("App");
      Adw.SwitchRow _background_row {
        title: _("Run in the background");
      }
      Adw.SwitchRow _quadratic_volume_row {
        title: _("Use quadratic volume control");
      }
      Adw.SwitchRow _video_cover_row {
        title: _("Display animated covers");
      }
      Adw.SwitchRow _discord_rpc_row {
        title: _("Enable Discord Rich Presence");
      }
    }

    Adw.PreferencesGroup _ai_settings_group {
      title: _("AI Radio");
      description: _("Your prompts, API key, recently-played favourites, and (when opted in) playlist names are sent to your selected provider. Nothing else leaves the device.");

      Adw.ComboRow _ai_provider_row {
        title: _("AI Provider");
        model: StringList {
          strings [
            "OpenAI",
            "Anthropic",
            "Google Gemini",
            "Ollama",
          ]
        };
      }

      Adw.PasswordEntryRow _ai_api_key_row {
        title: _("API Key");
      }

      Adw.EntryRow _ai_model_row {
        title: _("Model Override");
        show-apply-button: true;
      }

      Adw.EntryRow _ai_ollama_url_row {
        title: _("Ollama Server URL");
        show-apply-button: true;
      }

      Adw.SwitchRow _ai_use_critic_row {
        title: _("Enable quality filter");
        subtitle: _("A second AI pass removes off-topic tracks. Slower (~10s) and doubles API cost.");
      }
    }
  }
}
